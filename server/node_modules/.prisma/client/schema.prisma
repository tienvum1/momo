generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int        @id @default(autoincrement())
  email       String     @unique @db.VarChar(191)
  password    String     @db.VarChar(255)
  full_name   String     @db.VarChar(191)
  role        UserRole   @default(user)
  status      UserStatus @default(active)
  is_verified Boolean    @default(true)
  created_at  DateTime   @default(now())

  // Relations
  bookings Booking[] @relation("CustomerBookings")
  qrs      Qr[]      @relation("CreatorQrs")

  @@map("users")
}

enum UserRole {
  admin_system
  user
}

enum UserStatus {
  active
  locked
}

model Qr {
  id                   Int      @id @default(autoincrement())
  name                 String?  @db.VarChar(255)
  main_image           String?  @db.VarChar(255)
  qr_image             String?  @db.VarChar(255)
  max_amount_per_trans Decimal  @default(0) @db.Decimal(15, 2)
  monthly_limit        Decimal? @db.Decimal(15, 2)
  fee_rate             Decimal  @default(0) @db.Decimal(5, 2)
  fee_rate_under       Decimal  @default(0) @db.Decimal(5, 2)
  fee_rate_over        Decimal  @default(0) @db.Decimal(5, 2)
  note                 String?  @db.Text
  status               QrStatus @default(ready)
  creator_id           Int
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  // Relations
  creator  User      @relation("CreatorQrs", fields: [creator_id], references: [id])
  bookings Booking[]

  @@map("qrs")
}

enum QrStatus {
  ready
  maintenance
}

model Booking {
  id          Int    @id @default(autoincrement())
  code        String @unique @db.VarChar(50)
  qr_id       Int
  customer_id Int

  // Thông tin MoMo khách
  customer_account_number String @db.VarChar(60)
  customer_account_holder String @db.VarChar(255)

  // Tài chính
  transfer_amount Decimal @db.Decimal(15, 2)
  fee_rate        Decimal @default(0) @db.Decimal(5, 2)
  fee_amount      Decimal @default(0) @db.Decimal(15, 2)
  net_amount      Decimal @default(0) @db.Decimal(15, 2)

  // Chứng từ khách
  customer_paid_proof_url  String? @db.VarChar(255)
  customer_paid_proof_urls Json?
  customer_paid_note       String? @db.Text

  // Chứng từ admin
  admin_paid_proof_url  String?   @db.VarChar(255)
  admin_paid_proof_urls Json?
  admin_paid_at         DateTime?

  // Trạng thái
  status      BookingStatus @default(created)
  reject_note String?       @db.Text

  // Timestamps
  paid_at      DateTime?
  confirmed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  // Relations
  qr       Qr   @relation(fields: [qr_id], references: [id])
  customer User @relation("CustomerBookings", fields: [customer_id], references: [id])

  @@index([status])
  @@index([customer_id])
  @@index([created_at])
  @@map("bookings")
}

enum BookingStatus {
  created
  customer_paid
  confirmed
  rejected
  cancelled
}
